{
  "name": "VirtualAgent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent display name"
    },
    "role": {
      "type": "string",
      "description": "Agent role/title e.g. Customer Success"
    },
    "photo_url": {
      "type": "string",
      "description": "Agent profile photo URL"
    },
    "is_senior": {
      "type": "boolean",
      "default": false,
      "description": "Is this a senior agent"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Show this agent in pool"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.is_active": true
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}